"File: hal_tim_asymmetric_deadtime_insertion.csolution.yml" = """
# yaml-language-server: $schema=https://raw.githubusercontent.com/Open-CMSIS-Pack/devtools/schemas/projmgr/2.11.0/tools/projmgr/schemas/csolution.schema.json
solution:
  target-types:
    - type: NUCLEO-C542RC
      board: NUCLEO-C542RC:NUC542RC$KR1
      device: STM32C542RCT6
      define:
        - MX_PWM_CHANNEL_CHy: HAL_TIM_CHANNEL_1
          MX_PWM_CHANNEL_CHyN: HAL_TIM_CHANNEL_1N
  output-dirs:
    tmpdir: project/tmp
    outdir: $SolutionDir()$/build/$Project$.$BuildType$
  generators:
    base-dir: $ProjectDir()$/generated
    options:
      - generator: led_mx2codegen
        path: $SolutionDir()$/../generated/parts/led
      - generator: stm32c5xx_hal_mx2codegen
        path: $SolutionDir()$/../generated/hal/
      - generator: syscalls_mx2codegen
        path: $SolutionDir()$/../generated/utilities/syscalls
  build-types:
    - type: debug_GCC
      compiler: GCC
    - type: release_GCC
      compiler: GCC
    - type: debug_IAR
      compiler: IAR
    - type: release_IAR
      compiler: IAR
    - type: debug_AC6
      compiler: AC6
    - type: release_AC6
      compiler: AC6
  projects:
    - project: project/hal_tim_asymmetric_deadtime_insertion.cproject.yml
  packs:
    - pack: STMicroelectronics::button_hw-part@2.0.0
    - pack: STMicroelectronics::CMSIS@6.3.0
    - pack: STMicroelectronics::crystal_hw-part@2.1.0
    - pack: STMicroelectronics::esd_hw-part@2.1.0
    - pack: STMicroelectronics::led_hw-part@2.3.0
    - pack: STMicroelectronics::led_part_drivers@2.0.0
    - pack: STMicroelectronics::mcp2562fd_hw-part@2.0.0
    - pack: STMicroelectronics::nucleo-c542rc_hw-board@2.0.0
    - pack: STMicroelectronics::st-link_hw-part@2.0.0
    - pack: STMicroelectronics::stm32c5xx_dfp@2.0.0
    - pack: STMicroelectronics::stm32c5xx_hal_drivers@2.0.0
    - pack: STMicroelectronics::syscalls@2.0.0
"""
