    - setup: release_IAR
      misc:
        - C:
            - --debug
            - --dlib_config DLib_Config_Full.h
            - --no_wrap_diagnostics
            - --vla
            - --enable_restrict
            - -e
            - --require_prototypes
            - -Ohs
          CPP:
            - --debug
            - --dlib_config DLib_Config_Full.h
            - --no_wrap_diagnostics
            - --vla
            - --enable_restrict
            - -e
            - --require_prototypes
            - -Ohs
