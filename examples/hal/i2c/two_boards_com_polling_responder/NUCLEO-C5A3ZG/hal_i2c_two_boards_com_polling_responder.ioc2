            - --specs=nano.specs
            - --specs=nosys.specs
            - -Werror=implicit-function-declaration
          for-compiler: GCC
          Link-C:
            - -Wl,-Map=$OutDir()$/$Project$.map
            - -Wl,--gc-sections
            - -Wl,--start-group -lc -lm -Wl,--end-group
            - -static
            - --specs=nano.specs
            - --specs=nosys.specs
          Link-CPP:
