        <file category="header" name="mx_def.h"/>
        <file category="header" name="mx_system.h"/>
        <file category="source" name="mx_system.c"/>
        <file category="header" name="mx_cortex_nvic.h"/>
        <file category="source" name="mx_cortex_nvic.c"/>
        <file category="header" name="mx_gpio_default.h"/>
        <file category="source" name="mx_gpio_default.c"/>
        <file category="header" name="mx_rcc.h"/>
        <file category="source" name="mx_rcc.c"/>
        <file category="header" name="mx_usart2.h"/>
        <file category="source" name="mx_usart2.c"/>
        <file category="header" name="mx_flash.h"/>
        <file category="source" name="mx_flash.c"/>
      </files>
    </component>
  </components>
</package>
