            - -std=gnu++14
            - -fno-exceptions
            - -fno-rtti
            - -funsigned-char
            - -g
            - -Wmissing-prototypes
          for-compiler: AC6
          Link-C:
            - --map
            - --library_type=microlib
            - --symbols
            - --show_full_path
            - --inline
            - --any_contingency
          Link-CPP:
            - --library_type=microlib
            - --symbols
            - --map
            - --show_full_path
            - --inline
            - --any_contingency
      for-context:
