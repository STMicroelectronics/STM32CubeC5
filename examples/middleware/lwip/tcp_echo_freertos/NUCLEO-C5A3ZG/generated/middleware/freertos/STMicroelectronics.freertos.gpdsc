<package xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.0"
  xs:noNamespaceSchemaLocation="https://github.com/Open-CMSIS-Pack/Open-CMSIS-Pack-Spec/blob/main/schema/PACK.xsd">
  <vendor>STMicroelectronics</vendor>
  <name>freertos</name>
  <url>https://developer.st.com/st-pack-server/api/v1/pack/</url>
  <releases>
    <release version="2.0.0" date="2026-02-13">
      - First GPDSC FreeRTOS Model Release
    </release>
  </releases>
  <conditions>
    <condition id="GCC Compiler Condition">
    <description>Combined condition to check for GCC and AC6 compilers</description>
    <accept Tcompiler="GCC"/>
    <accept Tcompiler="ARMCC"/>
  </condition>
  <condition id="CM7 CM4 IAR Condition">
    <description>Cortex M7 (newer than r0p1) and CM4 / IAR compiler</description>
    <accept Dcore="Cortex-M7"/>
    <accept Dcore="Cortex-M4"/>
    <require Tcompiler="IAR"/>
  </condition>
  <condition id="CM7 CM4 GCC Condition">
    <description>Cortex M7 / GCC compiler</description>
    <accept Dcore="Cortex-M7"/>
    <accept Dcore="Cortex-M4"/>
    <require condition="GCC Compiler Condition"/>
  </condition>
  <condition id="CM0 IAR Condition">
    <description>Cortex M0 / IAR compiler</description>
    <require Dcore="Cortex-M0+"/>
    <require Tcompiler="IAR"/>
  </condition>
  <condition id="CM0 GCC Condition">
    <description>Cortex M0 / GCC compiler</description>
    <require Dcore="Cortex-M0+"/>
    <require condition="GCC Compiler Condition"/>
  </condition>
  <condition id="CM33 TZ Disabled IAR Condition">
    <description>Cortex M33 TZ Disabled / IAR compiler</description>
    <require Dcore="Cortex-M33"/>
    <require Dsecure="TZ-disabled"/>
    <require Tcompiler="IAR"/>
  </condition>
  <condition id="CM33 TZ Disabled GCC Condition">
    <description>Cortex M33 TZ Disabled / GCC compiler</description>
    <require Dcore="Cortex-M33"/>
    <require Dsecure="TZ-disabled"/>
    <require condition="GCC Compiler Condition"/>
  </condition>
  <condition id="CM85 IAR Condition">
    <description>Cortex M85 / IAR compiler</description>
    <require Dcore="Cortex-M85"/>
    <require Tcompiler="IAR"/>
    <accept Dsecure="Secure"/>
    <accept Dsecure="Secure-only"/>
  </condition>
  <condition id="CM85 GCC Condition">
    <description>Cortex M85 / GCC compiler</description>
    <require Dcore="Cortex-M85"/>
    <require condition="GCC Compiler Condition"/>
    <accept Dsecure="Secure"/>
    <accept Dsecure="Secure-only"/>
  </condition>
  <condition id="FreeRTOS Init condition">
    <description>STMicroelectronics FreeRTOS Init</description>
    <require condition="Stream Buffers condition"/>
    <require condition="FreeRTOS Memory Heap condition"/>
    <require Cclass="RTOS" Cgroup="FreeRTOS" Csub="Core"/>
  </condition>
    <condition id="Stream Buffers condition">
      <description>Stream Buffers condition</description>
    </condition>
    <condition id="FreeRTOS Memory Heap condition">
      <description>FreeRTOS Memory Heap condition</description>
      <require Cclass="RTOS" Cgroup="FreeRTOS" Csub="MemMang" Cvariant="Heap_4"/>
    </condition>
  </conditions>
  <components>
    <component generator="freertos_mx2codegen" Cclass="RTOS" Cgroup="STM32CubeMX2 Config" Csub="FreeRTOS"   Cversion="2.0.0" condition="FreeRTOS Init condition">
      <description>TO BE DEFINED</description>
      <files>
        <file category="header" name="FreeRTOSConfig.h" />
        <file category="source" name="mx_freertos_app.c" />
        <file category="header" name="mx_freertos_app.h" />
        <file category="other" name="mx_freertos_license.md" />
      </files>
    </component>
  </components>
</package>